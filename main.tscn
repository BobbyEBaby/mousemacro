theme_override_font_sizes/font_size = 16
theme_type_variation = &"RecordButton"
text = "Record"

[node name="PlayBtn" type="Button" parent="VBox/Buttons"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(130, 44)
theme_override_font_sizes/font_size = 16
theme_type_variation = &"AccentButton"
text = "Play"

