[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://main.gd" id="1_main"]
[ext_resource type="Theme" path="res://theme.tres" id="2_theme"]
[ext_resource type="Texture2D" path="res://assets/logo.svg" id="3_logo"]

[node name="Main" type="MarginContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
theme_override_constants/margin_left = 28
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 28
theme_override_constants/margin_bottom = 26
script = ExtResource("1_main")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Header" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 16

[node name="Logo" type="TextureRect" parent="VBox/Header"]
layout_mode = 2
custom_minimum_size = Vector2(80, 80)
texture = ExtResource("3_logo")
expand_mode = 1
stretch_mode = 5

[node name="TitleBox" type="VBoxContainer" parent="VBox/Header"]
layout_mode = 2
size_flags_vertical = 4
theme_override_constants/separation = 0

[node name="Title1" type="Label" parent="VBox/Header/TitleBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 17
text = "Mouse & Keyboard"

[node name="Title2" type="Label" parent="VBox/Header/TitleBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.878, 0.643, 0.345, 1)
theme_override_font_sizes/font_size = 27
text = "MACRO RECORDER"

[node name="Buttons" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 14

[node name="RecordBtn" type="Button" parent="VBox/Buttons"]
unique_name_in_owner = true
layout_mode = 2
