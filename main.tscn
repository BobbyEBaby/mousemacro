[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://main.gd" id="1_main"]

[node name="Main" type="MarginContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20
script = ExtResource("1_main")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Mouse Macro Recorder"
horizontal_alignment = 1

[node name="Sep1" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="Buttons" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 24

[node name="RecordBtn" type="Button" parent="VBox/Buttons"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(140, 44)
theme_override_font_sizes/font_size = 16
text = "Record"

[node name="PlayBtn" type="Button" parent="VBox/Buttons"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(140, 44)
theme_override_font_sizes/font_size = 16
text = "Play"

[node name="LoopRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1

[node name="LoopCheck" type="CheckBox" parent="VBox/LoopRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Loop playback"

[node name="LoopCountRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 8

[node name="LoopCountCheck" type="CheckBox" parent="VBox/LoopCountRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Limit to"

[node name="LoopCountSpin" type="SpinBox" parent="VBox/LoopCountRow"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(80, 0)
min_value = 1.0
max_value = 9999.0
value = 1.0

[node name="TimesLabel" type="Label" parent="VBox/LoopCountRow"]
layout_mode = 2
text = "loops"

[node name="Sep2" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="CountdownLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.4, 0.4, 1)
theme_override_font_sizes/font_size = 48
text = "3"
horizontal_alignment = 1

[node name="StatusLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 15
text = "Status: Idle"
horizontal_alignment = 1

[node name="EventsLabel" type="Label" parent="VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Events recorded: 0"
horizontal_alignment = 1

[node name="Sep3" type="HSeparator" parent="VBox"]
layout_mode = 2

[node name="HotkeyLabel" type="Label" parent="VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.65, 0.65, 0.65, 1)
text = "Space = Stop Recording   |   Esc = Stop Playback"
horizontal_alignment = 1
